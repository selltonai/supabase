[Unit]
Description=Sellton production Supabase Storage cloud to Hetzner sync
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/opt/sellton/live-sync/storage/storage-sync-run.sh
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6

