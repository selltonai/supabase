-- Migration script to transfer data from agent_runs/agent_messages to usage table
-- This is optional and only needed if you have existing data to migrate

-- Note: This migration assumes the old tables still exist. 
-- If they don't exist, this migration can be skipped.

-- Check if agent_runs table exists before attempting migration
DO $$
BEGIN
    IF EXISTS (SELECT 1 FROM information_schema.tables WHERE table_name = 'agent_runs') THEN
        -- Migrate agent_runs data to usage table
        INSERT INTO usage (
            organization_id,
            session_id,
            provider,
            model_name,
            api_calls,
            input_tokens,
            output_tokens,
            total_tokens,
            run_id,
            agent_id,
            description,
            usage_context,
            created_at,
            tracking_start,
            tracking_end,
            metadata
        )
        SELECT 
            organization_id,
            session_id,
            'openai' as provider, -- Default provider, adjust as needed
            model_name,
            1 as api_calls, -- Each run counts as 1 API call
            total_input_tokens as input_tokens,
            total_output_tokens as output_tokens,
            total_tokens,
            run_id,
            agent_id,
            content as description,
            COALESCE(event, 'direct_api') as usage_context,
            created_at,
            created_at as tracking_start,
            created_at as tracking_end,
            metrics_raw as metadata
        FROM agent_runs
        WHERE NOT EXISTS (
            SELECT 1 FROM usage u 
            WHERE u.run_id = agent_runs.run_id 
            AND u.organization_id = agent_runs.organization_id
        );
        
        RAISE NOTICE 'Migrated agent_runs data to usage table';
    ELSE
        RAISE NOTICE 'agent_runs table does not exist, skipping migration';
    END IF;
END $$;

-- Create daily summaries from usage data
INSERT INTO usage_summary (
    organization_id,
    provider,
    model_name,
    date,
    total_api_calls,
    total_input_tokens,
    total_output_tokens,
    total_tokens,
    unique_sessions
)
SELECT 
    organization_id,
    provider,
    model_name,
    DATE(created_at) as date,
    COUNT(*) as total_api_calls,
    SUM(input_tokens) as total_input_tokens,
    SUM(output_tokens) as total_output_tokens,
    SUM(total_tokens) as total_tokens,
    COUNT(DISTINCT session_id) as unique_sessions
FROM usage
GROUP BY organization_id, provider, model_name, DATE(created_at)
ON CONFLICT (organization_id, provider, model_name, date) 
DO UPDATE SET
    total_api_calls = EXCLUDED.total_api_calls,
    total_input_tokens = EXCLUDED.total_input_tokens,
    total_output_tokens = EXCLUDED.total_output_tokens,
    total_tokens = EXCLUDED.total_tokens,
    unique_sessions = EXCLUDED.unique_sessions,
    updated_at = NOW();

-- Add unique constraint if not exists
DO $$
BEGIN
    IF NOT EXISTS (
        SELECT 1 FROM pg_constraint 
        WHERE conname = 'usage_summary_unique_org_provider_model_date'
    ) THEN
        ALTER TABLE usage_summary 
        ADD CONSTRAINT usage_summary_unique_org_provider_model_date 
        UNIQUE (organization_id, provider, model_name, date);
    END IF;
END $$;